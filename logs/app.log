2026-04-26 18:36:15.236 DEBUG [http-nio-8081-exec-7] frontend - [voice-app.html] Parsed message {"jsonrpc":"2.0","method":"ui/notifications/tool-result","params":{"_meta":{"ui":{"resourceUri":"ui://voice-app"},"ui/resourceUri":"ui://voice-app","initialQuery":"HI"},"content":[{"type":"resource","resource":{"uri":"ui://voice-app","mimeType":"text/html;profile=mcp-app","_meta":{"ui":{"permissions":{"microphone":{}},"csp":{"connectDomains":["https://marvin.pelayomaojo.es","wss://marvin.pelayomaojo.es","http://localhost:8080","ws://localhost:8080","http://localhost:8081","ws://localhost:8081","https://cdn.jsdelivr.net","https://unpkg.com"],"resourceDomains":["https://cdn.jsdelivr.net","https://unpkg.com","https://fonts.googleapis.com","https://fonts.gstatic.com"],"script-src":["'self'","'unsafe-eval'","'wasm-unsafe-eval'","https://cdn.jsdelivr.net","https://unpkg.com"],"frameDomains":[],"worker-src":["'self'","blob:","https://cdn.jsdelivr.net","https://unpkg.com"]},"prefersBorder":true}},"text":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Voice Assistant - MCP App</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --primary: #6366f1;\n            --primary-glow: rgba(99, 102, 241, 0.4);\n            --bg: #0f172a;\n            --card-bg: rgba(30, 41, 59, 0.7);\n            --text: #f8fafc;\n            --text-dim: #94a3b8;\n        }\n\n        body {\n            font-family: 'Outfit', sans-serif;\n            background-color: var(--bg);\n            color: var(--text);\n            margin: 0;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n        }\n\n        .container {\n            background: var(--card-bg);\n            backdrop-filter: blur(12px);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            border-radius: 24px;\n            padding: 40px;\n            text-align: center;\n            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);\n            max-width: 400px;\n            width: 90%;\n            transition: transform 0.3s ease;\n        }\n\n        .visualizer {\n            height: 120px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 4px;\n            margin: 20px 0;\n        }\n\n        .bar {\n            width: 4px;\n            height: 10px;\n            background: var(--primary);\n            border-radius: 2px;\n            transition: height 0.1s ease;\n            box-shadow: 0 0 10px var(--primary-glow);\n        }\n\n        .status {\n            font-size: 1.2rem;\n            font-weight: 600;\n            margin-bottom: 8px;\n        }\n\n        .sub-status {\n            font-size: 0.9rem;\n            color: var(--text-dim);\n            margin-bottom: 24px;\n        }\n\n        .mic-button {\n            width: 80px;\n            height: 80px;\n            border-radius: 50%;\n            background: var(--primary);\n            border: none;\n            color: white;\n            font-size: 2rem;\n            cursor: pointer;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.3s ease;\n            box-shadow: 0 0 20px var(--primary-glow);\n            margin: 0 auto;\n        }\n\n        .mic-button:hover {\n            transform: scale(1.05);\n            box-shadow: 0 0 30px var(--primary-glow);\n        }\n\n        .mic-button.active {\n            background: #ef4444;\n            box-shadow: 0 0 30px rgba(239, 68, 68, 0.4);\n            animation: pulse 1.5s infinite;\n        }\n\n        @keyframes pulse {\n            0% { transform: scale(1); }\n            50% { transform: scale(1.05); }\n            100% { transform: scale(1); }\n        }\n\n        .initial-query {\n            margin-top: 24px;\n            padding: 16px;\n            background: rgba(0, 0, 0, 0.2);\n            border-radius: 12px;\n            font-style: italic;\n            color: var(--text-dim);\n            font-size: 0.9rem;\n            text-align: left;\n        }\n\n        .transcript {\n            margin-top: 16px;\n            font-size: 0.9rem;\n            min-height: 1.2rem;\n        }\n\n        /* SVG Icons */\n        .icon { width: 32px; height: 32px; fill: currentColor; }\n    </style>\n</head>\n<body>\n\n    <div class=\"container\">\n        <div class=\"status\" id=\"status\">Voice Assistant</div>\n        <div class=\"sub-status\" id=\"sub-status\">Initializing...</div>\n\n        <div class=\"visualizer\" id=\"visualizer\">\n            <!-- Bars will be generated by JS -->\n        </div>\n\n        <button class=\"mic-button\" id=\"mic-btn\">\n            <svg class=\"icon\" viewBox=\"0 0 24 24\">\n                <path d=\"M12 14c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3S9 3.34 9 5v6c0 1.66 1.34 3 3 3z\"/>\n                <path d=\"M17 11c0 2.76-2.24 5-5 5s-5-2.24-5-5H5c0 3.53 2.61 6.43 6 6.92V21h2v-3.08c3.39-.49 6-3.39 6-6.92h-2z\"/>\n            </svg>\n        </button>\n\n        <div style=\"margin-top: 10px;\">\n            <button id=\"auth-btn\" style=\"background: none; border: 1px solid var(--text-dim); color: var(--text-dim); padding: 4px 8px; border-radius: 4px; font-size: 0.7rem; cursor: pointer;\">\n                Authorize Mic manually\n            </button>\n        </div>\n\n        <div class=\"transcript\" id=\"transcript\"></div>\n\n        <div class=\"initial-query\" id=\"initial-query-container\" style=\"display: none;\">\n            <strong>Contexto:</strong> <span id=\"initial-query\"></span>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/onnxruntime-web@1.14.0/dist/ort.js\"></script>\n    <script src=\"https://cdn.jsdelivr.net/npm/@ricky0123/vad-web@0.0.22/dist/bundle.min.js\"></script>\n    <script type=\"module\">\n        import { App } from \"https://unpkg.com/@modelcontextprotocol/ext-apps@1.4.0/app-with-deps\";\n\n        const app = new App({\n            name: \"voice-assistant-ui\",\n            version: \"1.0.0\",\n            capabilities: {\n                permissions: { microphone: {} }\n            }\n        });\n\n        const params = new URLSearchParams(window.location.search);\n        const PUBLIC_BACKEND = 'https://marvin.pelayomaojo.es';\n        \n        // Better detection: if we are on localhost, try to use localhost:8081\n        const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';\n        const defaultLocal = `http://${window.location.hostname}:8081`;\n        \n        const backendBaseUrl = params.get('backend')\n            || (isLocalhost ? defaultLocal : PUBLIC_BACKEND);\n\n        // --- Reenvío de logs del navegador al backend (centralizador) ---\n        (function installLogForwarder() {\n            const levels = ['log', 'info', 'warn', 'error', 'debug'];\n            const original = {};\n            const send = (level, args) => {\n                try {\n                    const message = args.map(a => {\n                        if (a instanceof Error) return a.stack || a.message;\n                        if (typeof a === 'object') { try { return JSON.stringify(a); } catch { return String(a); } }\n                        return String(a);\n                    }).join(' ');\n                    fetch(backendBaseUrl + '/api/logs', {\n                        method: 'POST',\n                        headers: { 'Content-Type': 'application/json' },\n                        body: JSON.stringify({ level: level === 'log' ? 'info' : level, message, source: 'voice-app.html' }),\n                        keepalive: true\n                    }).catch(() => {});\n                } catch {}\n            };\n            levels.forEach(lvl => {\n                original[lvl] = console[lvl].bind(console);\n                console[lvl] = (...args) => { send(lvl, args); original[lvl](...args); };\n            });\n            window.addEventListener('error', e => send('error', [e.message, e.filename + ':' + e.lineno]));\n            window.addEventListener('unhandledrejection', e => send('error', ['unhandledrejection', e.reason]));\n        })();\n\n        let vadInstance = null;\n        let isListening = false;\n        let isBusy = false;\n        let socket = null;\n\n        const micBtn = document.getElementById('mic-btn');\n        const statusEl = document.getElementById('status');\n        const subStatusEl = document.getElementById('sub-status');\n        const visualizer = document.getElementById('visualizer');\n        const transcriptEl = document.getElementById('transcript');\n        const initialQueryEl = document.getElementById('initial-query');\n        const initialQueryContainer = document.getElementById('initial-query-container');\n\n        // Create visualizer bars\n        for (let i = 0; i < 20; i++) {\n            const bar = document.createElement('div');\n            bar.className = 'bar';\n            visualizer.appendChild(bar);\n        }\n\n        const bars = document.querySelectorAll('.bar');\n\n        app.ontoolinput = (input) => {\n            const query = input?.arguments?.initialQuery;\n            if (query) {\n                initialQueryEl.textContent = query;\n                initialQueryContainer.style.display = 'block';\n            }\n        };\n\n        async function connectWebSocket() {\n            return new Promise((resolve) => {\n                const wsUrl = backendBaseUrl.replace(/^http/, 'ws') + '/ws/voice';\n                \n                console.log(`Connecting to WebSocket: ${wsUrl}`);\n                socket = new WebSocket(wsUrl);\n                socket.binaryType = 'arraybuffer';\n\n                socket.onopen = () => {\n                    console.info(\"WebSocket connected\");\n                    subStatusEl.textContent = \"Ready (Streaming)\";\n                    \n                    // Heartbeat to keep connection alive\n                    const heartbeat = setInterval(() => {\n                        if (socket.readyState === WebSocket.OPEN) {\n                            socket.send(\"PING\");\n                        } else {\n                            clearInterval(heartbeat);\n                        }\n                    }, 20000);\n                    \n                    resolve(true);\n                };\n\n                socket.onmessage = (event) => {\n                    try {\n                        const result = JSON.parse(event.data);\n                        if (result.status === 'success') {\n                            transcriptEl.textContent = result.text || '';\n                            playAssistantAudio(result.audio, result.audioMimeType || 'audio/wav');\n                        } else {\n                            console.error(\"Server error:\", result.message);\n                            subStatusEl.textContent = \"Error: \" + result.message;\n                        }\n                    } catch (e) {\n                        console.error(\"Error parsing socket message\", e);\n                    }\n                    isBusy = false;\n                    if (isListening) {\n                        statusEl.textContent = \"Listening…\";\n                        subStatusEl.textContent = \"Channel open\";\n                    }\n                };\n\n                socket.onerror = (err) => {\n                    console.error(\"WebSocket error\", err);\n                    subStatusEl.textContent = \"Socket error, using fallback\";\n                    resolve(false);\n                };\n\n                socket.onclose = () => {\n                    console.warn(\"WebSocket closed\");\n                    setTimeout(connectWebSocket, 5000); // Reconnect\n                };\n            });\n        }\n\n        app.connect().then(async () => {\n            console.log(\"MCP Connected successfully\");\n            await connectWebSocket();\n        }).catch(err => {\n            console.error(\"MCP Connection failed details:\", {\n                message: err.message,\n                code: err.code,\n                data: err.data,\n                stack: err.stack\n            });\n            subStatusEl.textContent = \"Local demo mode (Connection failed)\";\n        });\n\n        micBtn.addEventListener('click', toggleListening);\n        document.getElementById('auth-btn').addEventListener('click', async () => {\n            try {\n                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });\n                console.log(\"Manual mic access success\");\n                stream.getTracks().forEach(t => t.stop());\n                subStatusEl.textContent = \"Mic Authorized\";\n            } catch (err) {\n                console.error(\"Manual mic access failed\", err);\n                subStatusEl.textContent = \"Auth failed: \" + err.message;\n            }\n        });\n\n        async function toggleListening() {\n            if (isListening) {\n                stopListening();\n            } else {\n                await startListening();\n            }\n        }\n\n        async function startListening() {\n            try {\n                if (!vadInstance) {\n                    statusEl.textContent = \"Loading…\";\n                    subStatusEl.textContent = \"Initializing voice detector\";\n                    const cdn = \"https://cdn.jsdelivr.net/npm/@ricky0123/vad-web@0.0.22/dist/\";\n                    vadInstance = await vad.MicVAD.new({\n                        baseAssetPath: cdn,\n                        onnxWASMBasePath: \"https://cdn.jsdelivr.net/npm/onnxruntime-web@1.14.0/dist/\",\n                        positiveSpeechThreshold: 0.7,\n                        negativeSpeechThreshold: 0.5,\n                        minSpeechFrames: 4,\n                        redemptionFrames: 12,\n                        onSpeechStart: () => {\n                            if (isBusy) return;\n                            statusEl.textContent = \"Listening…\";\n                            subStatusEl.textContent = \"Speech detected\";\n                            if (socket && socket.readyState === WebSocket.OPEN) {\n                                socket.send(\"CLEAR\");\n                            }\n                        },\n                        onSpeechEnd: async (audio) => {\n                            if (isBusy) return;\n                            isBusy = true;\n                            try {\n                                statusEl.textContent = \"Processing…\";\n                                subStatusEl.textContent = \"Sending stream\";\n                                await sendUtterance(audio);\n                            } finally {\n                                // isBusy remains true until socket message received\n                            }\n                        },\n                        onVADMisfire: () => {\n                            if (isListening && !isBusy) {\n                                subStatusEl.textContent = \"Channel open\";\n                            }\n                        }\n                    });\n                }\n                vadInstance.start();\n                isListening = true;\n                micBtn.classList.add('active');\n                statusEl.textContent = \"Listening…\";\n                subStatusEl.textContent = \"Channel open\";\n            } catch (err) {\n                console.error(\"VAD init failed\", err);\n                statusEl.textContent = \"Error\";\n                subStatusEl.textContent = \"Microphone or VAD failed\";\n            }\n        }\n\n        function stopListening() {\n            if (vadInstance) vadInstance.pause();\n            isListening = false;\n            micBtn.classList.remove('active');\n            statusEl.textContent = \"Idle\";\n            subStatusEl.textContent = \"Channel closed\";\n        }\n\n        async function sendUtterance(float32Pcm16k) {\n            const wavBlob = encodeWav(float32Pcm16k, 16000);\n            \n            // Try WebSocket first\n            if (socket && socket.readyState === WebSocket.OPEN) {\n                const arrayBuffer = await wavBlob.arrayBuffer();\n                socket.send(arrayBuffer);\n                socket.send(\"PROCESS\");\n                return;\n            }\n\n            // Fallback to MCP Tool Bridge\n            console.log(\"WebSocket not available, falling back to MCP Tool\");\n            const base64Audio = await blobToBase64(wavBlob);\n            try {\n                const result = await app.callTool(\"processVoice\", { audio: base64Audio });\n                transcriptEl.textContent = result.text || '';\n                playAssistantAudio(result.audio, result.audioMimeType || 'audio/wav');\n                isBusy = false;\n            } catch (err) {\n                console.error(\"Voice processing failed via MCP\", err);\n                // Last resort: direct fetch\n                try {\n                    const response = await fetch(`${backendBaseUrl}/api/voice/process`, {\n                        method: 'POST',\n                        headers: { 'Content-Type': 'application/json' },\n                        body: JSON.stringify({ audio: base64Audio, mimeType: 'audio/wav' })\n                    });\n                    const result = await response.json();\n                    transcriptEl.textContent = result.text || '';\n                    playAssistantAudio(result.audio, result.audioMimeType || 'audio/wav');\n                } catch (fetchErr) {\n                    subStatusEl.textContent = \"All connection paths failed\";\n                }\n                isBusy = false;\n            }\n        }\n\n        function blobToBase64(blob) {\n            return new Promise((resolve, reject) => {\n                const reader = new FileReader();\n                reader.onloadend = () => resolve(String(reader.result).split(',')[1]);\n                reader.onerror = reject;\n                reader.readAsDataURL(blob);\n            });\n        }\n\n        function encodeWav(samples, sampleRate) {\n            const buffer = new ArrayBuffer(44 + samples.length * 2);\n            const view = new DataView(buffer);\n            const writeStr = (off, s) => { for (let i = 0; i < s.length; i++) view.setUint8(off + i, s.charCodeAt(i)); };\n            writeStr(0, 'RIFF');\n            view.setUint32(4, 36 + samples.length * 2, true);\n            writeStr(8, 'WAVE');\n            writeStr(12, 'fmt ');\n            view.setUint32(16, 16, true);\n            view.setUint16(20, 1, true);\n            view.setUint16(22, 1, true);\n            view.setUint32(24, sampleRate, true);\n            view.setUint32(28, sampleRate * 2, true);\n            view.setUint16(32, 2, true);\n            view.setUint16(34, 16, true);\n            writeStr(36, 'data');\n            view.setUint32(40, samples.length * 2, true);\n            let offset = 44;\n            for (let i = 0; i < samples.length; i++, offset += 2) {\n                const s = Math.max(-1, Math.min(1, samples[i]));\n                view.setInt16(offset, s < 0 ? s * 0x8000 : s * 0x7fff, true);\n            }\n            return new Blob([view], { type: 'audio/wav' });\n        }\n\n        function playAssistantAudio(base64Audio, mimeType) {\n            if (!base64Audio) {\n                return;\n            }\n\n            const audio = new Audio(`data:${mimeType};base64,${base64Audio}`);\n            audio.play().catch(err => {\n                console.warn(\"Audio playback failed\", err);\n            });\n        }\n\n        function preferredRecordingMimeType() {\n            const candidates = [\n                'audio/webm;codecs=opus',\n                'audio/webm',\n                'audio/ogg;codecs=opus',\n                'audio/mp4'\n            ];\n\n            return candidates.find(type => MediaRecorder.isTypeSupported(type)) || '';\n        }\n\n        let audioContext, analyser, dataArray, animationId;\n\n        function startVisualizer(stream) {\n            audioContext = new (window.AudioContext || window.webkitAudioContext)();\n            analyser = audioContext.createAnalyser();\n            const source = audioContext.createMediaStreamSource(stream);\n            source.connect(analyser);\n            analyser.fftSize = 64;\n            const bufferLength = analyser.frequencyBinCount;\n            dataArray = new Uint8Array(bufferLength);\n\n            function update() {\n                analyser.getByteFrequencyData(dataArray);\n                for (let i = 0; i < bars.length; i++) {\n                    const value = dataArray[i] / 2;\n                    bars[i].style.height = Math.max(10, value) + 'px';\n                }\n                animationId = requestAnimationFrame(update);\n            }\n            update();\n        }\n\n        function stopVisualizer() {\n            cancelAnimationFrame(animationId);\n            bars.forEach(bar => bar.style.height = '10px');\n            if (audioContext) audioContext.close();\n        }\n    </script>\n</body>\n</html>\n"},"_meta":{"ui":{"permissions":{"microphone":{}},"csp":{"connectDomains":["https://marvin.pelayomaojo.es","wss://marvin.pelayomaojo.es","http://localhost:8080","ws://localhost:8080","http://localhost:8081","ws://localhost:8081","https://cdn.jsdelivr.net","https://unpkg.com"],"resourceDomains":["https://cdn.jsdelivr.net","https://unpkg.com","https://fonts.googleapis.com","https://fonts.gstatic.com"],"script-src":["'self'","'unsafe-eval'","'wasm-unsafe-eval'","https://cdn.jsdelivr.net","https://unpkg.com"],"frameDomains":[],"worker-src":["'self'","blob:","https://cdn.jsdelivr.net","https://unpkg.com"]},"prefersBorder":true}}}],"isError":false}}
